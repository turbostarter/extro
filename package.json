    "@webext-core/messaging": "^3.0.2",
    "ai": "^4.3.19",
    "chrome-ai": "^1.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "envin": "^1.2.0",
    "lucide-react": "^1.18.0",
    "marked": "^18.0.5",
    "next-themes": "^0.4.6",
    "npm-run-all": "^4.1.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
